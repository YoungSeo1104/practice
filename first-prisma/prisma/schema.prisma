// Prisma Client 생성 설정
generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

// 데이터베이스 연결 설정
datasource db {
    provider = "postgresql"
}

model User {
    id        Int      @id @default(autoincrement()) //자동으로 증가하는 번호
    email     String   @unique
    name      String
    posts     Post[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Post {
    id        Int      @id @default(autoincrement())
    title     String
    content   String? //?는 임시저장, 게시물을 비워도 됨
    published Boolean  @default(false)
    author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
    authorId  Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
